from huggingface_hub import HfApi, create_repo, upload_folder
import os

# ================= CONFIG =================
HF_USERNAME = "teohyc"   # change this
REPO_NAME = "Satellite-Road-Segmentation-UNet"  

TEMP_DIR = "hf_upload"

#prepare folder
os.makedirs(TEMP_DIR, exist_ok=True)

